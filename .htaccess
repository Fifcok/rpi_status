# Konfiguracja Apache dla RPi5 Admin Dashboard.

# Wyłącz listowanie katalogów.
Options -Indexes

# Podstawowe nagłówki bezpieczeństwa.
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "same-origin"
</IfModule>

# Blokada bezpośredniego dostępu do plików wrażliwych.
<FilesMatch "\.(sqlite|sql|log|md|env)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
